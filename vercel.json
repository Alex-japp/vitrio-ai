{
  "functions": {
    "api/inngest.js": {
      "maxDuration": 300
    },
    "api/criar-job.js": {
      "maxDuration": 30
    },
    "api/status.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "vitrio-ai.vercel.app"
        }
      ],
      "destination": "https://vitrioai.com.br/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.vitrioai.com.br"
        }
      ],
      "destination": "https://vitrioai.com.br/$1",
      "permanent": true
    }
  ]
}
